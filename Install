#!/bin/bash
set -e

export DOTDOT="${HOME}/bin/nix_conf"

#Create symlinks for the configs
ln -sfn "${DOTDOT}/bashrc" ~/.bashrc
echo ". ~/.bashrc" > ~/.bash_profile
source ~/.bashrc

# First level symlinks
for rc in inputrc fdignore ctags pythonstartup ackrc editorconfig ideavimrc pdbrc virtualenv aider.conf.yml; do
    ln -sfn "${DOTDOT}/$rc" ~/."$rc"
done

# Deeper symlinks
for rc in git/gitconfig git/gitk vim/vimrc vim/vim tmux/tmux.conf mutt/muttrc; do
    ln -sfn "${DOTDOT}/$rc" ~/."$(basename "$rc")"
done

mkdir -p ~/.gemini ~/.claude ~/.ssh ~/.config/kitty ~/.pip
ln -sfn "${DOTDOT}/ai/gemini_settings.json" ~/.gemini/settings.json
ln -sfn "${DOTDOT}/ai/geminiignore" ~/.gemini/.geminiignore
ln -sfn "${DOTDOT}/ai/claude_settings.json" ~/.claude/settings.json
ln -sfn "${DOTDOT}/ssh/config" ~/.ssh/config
ln -sfn "${DOTDOT}/kitty.conf" ~/.config/kitty/kitty.conf
ln -sfn "${DOTDOT}/pip.conf" ~/.pip/pip.conf
ln -sfn "${DOTDOT}/.prettierrc.json" ~/.prettierrc.json

# Ensure the destination directory exists
mkdir -p ~/Library/Application\ Support/espanso

# Link the config and match directories
ln -sfn "${DOTDOT}/espanso/config" ~/Library/Application\ Support/espanso/config
ln -sfn "${DOTDOT}/espanso/match" ~/Library/Application\ Support/espanso/match

#create a .tmp directory for vim backups
mkdir -p ~/.tmp

git submodule update --init