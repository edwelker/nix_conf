# Brewfile combined from brewfile.cli and brewfile.gui

# The main cask tap is usually tapped by default, but it doesn't hurt to be explicit
# tap "homebrew/bundle"
# tap "homebrew/cask"

# CLI Tools
brew "bash"
brew "git"
brew "python3"
brew "tmux"
brew "ack"
brew "wget"
brew "tree"
brew "node"
brew "nvm"
brew "bash-completion"
brew "irssi"
brew "jq"
brew "autossh"
brew "mosh"
brew "libev"
# brew install mutt
brew "go"
brew "gnu-sed"
# brew install the_silver_searcher
brew "universal-ctags"
brew "pstree"
brew "watch"
brew "fzf"
brew "fd"
brew "ripgrep"
# brew "rvm"
brew "tre"
brew "bat"
brew "dasel"
brew "git-delta"
brew "gauth"
brew "fclones"
brew "rsync" # get a modern version
brew "mole"
brew "tealdeer"
brew "vim"
brew "aider"
brew "gemini-cli"
brew "svn"

# opensc for that stupid card reader, then you have to change the ssh call to point
# to /usr/local/Cellar/opensc/0.13.0/lib/pkcs11/opensc-pkcs11.so
brew "opensc"

# added tools
brew "uv"
brew "ruff"
brew "btop"

